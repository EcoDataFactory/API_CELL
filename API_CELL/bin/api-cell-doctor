#!/data/data/com.termux/files/usr/bin/sh
set -eu

echo "### API_CELL DOCTOR"

echo
echo "### comandos"
for c in git python curl gh; do
  if command -v "$c" >/dev/null 2>&1; then
    echo "OK command: $c"
  else
    echo "MISSING command: $c"
  fi
done

echo
echo "### comandos API_CELL"
for c in \
  API_CELL/bin/api-cell-start \
  API_CELL/bin/api-cell-stop \
  API_CELL/bin/api-cell-restart \
  API_CELL/bin/api-cell-port \
  API_CELL/bin/api-cell-narrador \
  API_CELL/bin/api-cell-test-all \
  API_CELL/bin/api-cell-cycle \
  API_CELL/bin/api-cell-doctor \
  API_CELL/bin/api-cell-help \
  API_CELL/bin/api-cell-open \
  API_CELL/bin/api-cell-follow-log
do
  if [ -x "$c" ]; then
    echo "OK command: $c"
  else
    echo "MISSING command: $c"
  fi
done

echo
echo "### archivos"
for f in \
  README.md \
  API_CELL/src/api_cell/__init__.py \
  API_CELL/src/api_cell/app.py \
  API_CELL/src/api_cell/core.py \
  API_CELL/src/api_cell/routes.py \
  API_CELL/src/api_cell/server.py \
  API_CELL/bin/api-cell
do
  if [ -e "$f" ]; then
    echo "OK file: $f"
  else
    echo "MISSING file: $f"
  fi
done

echo
echo "### puerto"
API_CELL/bin/api-cell-port || true

echo
echo "### status local si esta arriba"
if API_CELL/bin/api-cell-port >/dev/null 2>&1; then
  API_CELL/bin/api-cell-get-status || true
else
  echo "INFO: API_CELL no esta corriendo"
fi

echo
echo "### git"
git status --short
git --no-pager log --oneline --decorate --graph --max-count=8

echo
echo "### remotos"
git remote -v
git ls-remote --heads api-cell || true
git ls-remote --tags api-cell | grep -E 'v0.1.0-public-api-cell|v0.1.1-public-api-cell|v0.1.2-public-api-cell|v0.1.3-public-api-cell' || true

echo
echo "OK: doctor terminado"
