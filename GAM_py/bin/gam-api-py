#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path

HOME = Path.home()
CELL = HOME / "GAM_CELL"
BASE = CELL / "GAM_py"
LIVE_SRC = BASE / "live-src"
PKI = HOME / "GAM_CELL_PKI" / "GAM_py"
CONFIG = PKI / "config"
API_JSON = PKI
RUNTIME = BASE / "api-runtime"
GAM_PY = LIVE_SRC / "gam.py"

def _env():
    env = os.environ.copy()
    env.setdefault("GAM_CELL", str(CELL))
    env.setdefault("GAM_CELL_BASE", str(BASE))
    env.setdefault("GAM_CELL_LIVE_SRC", str(LIVE_SRC))
    env.setdefault("GAM_CELL_CONFIG", str(CONFIG))
    env.setdefault("GAM_CELL_API_JSON", str(API_JSON))
    env.setdefault("GAM_CELL_RUNTIME", str(RUNTIME))
    env.setdefault("GAM_CELL_CACERTS_PEM", str(PKI / "certs" / "cacerts.pem"))
    env.setdefault("PYTHONPATH", str(LIVE_SRC))
    return env

def run_gam(args):
    return subprocess.run(
        [sys.executable, str(GAM_PY), *args],
        cwd=str(LIVE_SRC),
        env=_env(),
    )

def status():
    paths = {
        "cell": CELL,
        "base": BASE,
        "live_src": LIVE_SRC,
        "live_config": CONFIG,
        "api_json": API_JSON,
        "runtime": RUNTIME,
        "gam_py": GAM_PY,
    }

    print("GAM_CELL API Python self-contained")
    for k, v in paths.items():
        print(f"{k + ':':<12} {v}")

    required = [CELL, BASE, LIVE_SRC, CONFIG, RUNTIME, GAM_PY]
    for p in required:
        if p.exists():
            print(f"OK: {p}")
        else:
            print(f"ERROR: missing {p}")
            return 1

    if API_JSON.exists():
        print(f"OK optional: {API_JSON}")
    else:
        print(f"WARN optional missing: {API_JSON}")

    return 0

def json_keys():
    for name in ("config", "auth-client", "auth-service", "auth-user", "certs", "discovery", "hashes", "cache"):
        p = API_JSON / name
        print(f"{name}: {p} {'OK' if p.exists() else 'MISSING'}")
    return 0

def help_text():
    print("""Uso:
  gam-api-py status
  gam-api-py version
  gam-api-py checkconn
  gam-api-py json keys
  gam-api-py gam <args...>

Descripción:
  API Python interna autosuficiente de GAM_CELL.
  Usa live-src como source real y PKI externa.
""")
    return 0

def main(argv):
    cmd = argv[1] if len(argv) > 1 else "help"
    rest = argv[2:]

    if cmd in ("help", "-h", "--help"):
        return help_text()

    if cmd == "status":
        return status()

    if cmd == "version":
        return run_gam(["version"]).returncode

    if cmd == "checkconn":
        return run_gam(["checkconn"]).returncode

    if cmd == "json":
        sub = rest[0] if rest else "keys"
        if sub == "keys":
            return json_keys()
        print("Uso: gam-api-py json keys")
        return 2

    if cmd == "gam":
        return run_gam(rest).returncode

    print(f"ERROR: comando no reconocido: {cmd}")
    print("Usa: gam-api-py help")
    return 2

if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
