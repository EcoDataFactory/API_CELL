#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

CELL="$HOME/GAM_CELL"
PY="$CELL/GAM_py"
SRC="$PY/live-src"
BIN="$PY/bin"
PKI="$HOME/GAM_CELL_PKI/GAM_py"
CONFIG="$PKI/config"
RUNTIME="$PKI/runtime"
DISCOVERY="$PKI/discovery"
CERTS="$PKI/certs"
CACERTS="$CERTS/cacerts.pem"

export GAMCFGDIR="$CONFIG"
export PYTHONDONTWRITEBYTECODE=1
export PYTHONPATH="$SRC${PYTHONPATH:+:$PYTHONPATH}"

export GAM_CELL="$CELL"
export GAM_CELL_BASE="$PY"
export GAM_CELL_LIVE_SRC="$SRC"
export GAM_CELL_CONFIG="$CONFIG"
export GAM_CELL_API_JSON="$PKI"
export GAM_CELL_RUNTIME="$RUNTIME"
export GAM_CELL_CACERTS_PEM="$CACERTS"

# Compatibilidad temporal con nombres TEC_GAM_* usados por scripts viejos.
export TEC_GAM_CELL="$CELL"
export TEC_GAM_PY="$PY"
export TEC_GAM_PY_SRC="$SRC"
export TEC_GAM_PY_CONFIG="$CONFIG"
export TEC_GAM_PY_PKI="$PKI"
export TEC_GAM_API_JSON="$PKI"
export TEC_GAM_API_RUNTIME="$RUNTIME"
export TEC_GAM_API_PY="$BIN/gam-api-py"

cmd="${1:-help}"
shift || true

case "$cmd" in
  live|run)
    if [ ! -d "$GAMCFGDIR" ]; then
      echo "ERROR: falta GAMCFGDIR=$GAMCFGDIR"
      exit 1
    fi
    if [ ! -f "$SRC/gam.py" ]; then
      echo "ERROR: falta $SRC/gam.py"
      exit 1
    fi
    cd "$SRC"
    exec python "$SRC/gam.py" "$@"
    ;;

  api|api-py)
    exec "$BIN/gam-api-py" "$@"
    ;;

  json)
    sub="${1:-keys}"
    shift || true
    case "$sub" in
      keys)
        exec "$BIN/gam-api-py" json keys
        ;;
      list)
        ls -la "$PKI"
        ;;
      status)
        exec "$BIN/gam-api-py" status
        ;;
      *)
        echo "Uso:"
        echo "  gam json keys"
        echo "  gam json list"
        echo "  gam json status"
        exit 2
        ;;
    esac
    ;;

  pki|config)
    echo "GAM_py PKI externa"
    echo "PKI=$PKI"
    echo "GAMCFGDIR=$GAMCFGDIR"
    echo "CACERTS=$CACERTS"
    echo
    for d in auth-client auth-user auth-service config certs discovery hashes cache runtime; do
      if [ -d "$PKI/$d" ]; then
        echo "$d:"
        ls -la "$PKI/$d"
        echo
      fi
    done
    ;;

  status)
    echo "GAM_py bin unico"
    echo "PY=$PY"
    echo "SRC=$SRC"
    echo "CONFIG=$CONFIG"
    echo "PKI=$PKI"
    echo "RUNTIME=$RUNTIME"
    echo "API=$BIN/gam-api-py"
    echo "CACERTS=$CACERTS"
    ;;

  audit|auditar)
    exec bash "$HOME/GAM_CELL_ROTATE_REVOKE_AUDIT.sh" audit
    ;;

  rotate|rotar|token|oauth-token)
    exec bash "$HOME/GAM_CELL_ROTATE_REVOKE_AUDIT.sh" rotate
    ;;

  help|-h|--help)
    cat <<HELP
Uso:
  gam live --version
  gam live checkconn

  gam api status
  gam api version
  gam api checkconn
  gam api json keys

  gam json keys
  gam json list
  gam json status

  gam pki
  gam status
HELP
    ;;

  *)
    echo "ERROR: comando no reconocido: $cmd"
    echo "Usa: gam help"
    exit 2
    ;;
esac
