#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

CELL="$HOME/GAM_CELL"
PY="$CELL/GAM_py"
SRC="$PY/src"
BIN="$PY/bin"
PKI="$HOME/GAM_CELL_PKI/GAM_py"
CONFIG="$PKI/config"
RUNTIME="$PKI/runtime"
DISCOVERY="$PKI/discovery"
CERTS="$PKI/certs"
CACERTS="$CERTS/cacerts.pem"

export GAMCFGDIR="$CONFIG"
export PYTHONDONTWRITEBYTECODE=1
export PYTHONPATH="$SRC/gam:$SRC/vendor:$SRC${PYTHONPATH:+:$PYTHONPATH}"

export GAM_CELL="$CELL"
export GAM_CELL_BASE="$PY"
export GAM_CELL_LIVE_SRC="$SRC"
export GAM_CELL_CONFIG="$CONFIG"
export GAM_CELL_API_JSON="$PKI"
export GAM_CELL_RUNTIME="$RUNTIME"
export GAM_CELL_CACERTS_PEM="$CACERTS"

# Compatibilidad temporal con nombres TEC_GAM_* usados por scripts viejos.
export TEC_GAM_CELL="$CELL"
export TEC_GAM_PY="$PY"
export TEC_GAM_PY_SRC="$SRC"
export TEC_GAM_PY_CONFIG="$CONFIG"
export TEC_GAM_PY_PKI="$PKI"
export TEC_GAM_API_JSON="$PKI"
export TEC_GAM_API_RUNTIME="$RUNTIME"
export TEC_GAM_API_PY="$SRC/gam/gam_api.py"


doctor_runtime() {
  echo "GAM_py runtime doctor"

  echo
  echo "### rutas"
  for path in \
    "$CELL" \
    "$PY" \
    "$SRC" \
    "$CONFIG" \
    "$PKI" \
    "$RUNTIME" \
    "$SRC/atom" \
    "$SRC/vendor" \
    "$SRC/vendor/gdata" \
    "$SRC/gam" \
    "$SRC/gam/gamlib"
  do
    if [ ! -d "$path" ]; then
      echo "ERROR: falta directorio: $path" >&2
      exit 1
    fi
    echo "OK dir: $path"
  done

  for file in \
    "$SRC/bin/gam" \
    "$SRC/gam/gam.py" \
    "$SRC/gam/gam_api.py" \
    "$SRC/atom/__init__.py" \
    "$SRC/vendor/gdata/__init__.py" \
    "$SRC/gam/gamlib/__init__.py"
  do
    if [ ! -f "$file" ]; then
      echo "ERROR: falta archivo: $file" >&2
      exit 1
    fi
    echo "OK file: $file"
  done

  echo
  echo "### permisos"
  if [ ! -x "$SRC/bin/gam" ]; then
    echo "ERROR: no ejecutable: $SRC/bin/gam" >&2
    exit 1
  fi
  echo "OK executable: $SRC/bin/gam"

  if [ ! -x "$SRC/gam/gam.py" ]; then
    echo "ERROR: no ejecutable: $SRC/gam/gam.py" >&2
    exit 1
  fi
  echo "OK executable: $SRC/gam/gam.py"

  if [ ! -r "$SRC/gam/gam_api.py" ]; then
    echo "ERROR: no legible: $SRC/gam/gam_api.py" >&2
    exit 1
  fi
  echo "OK readable: $SRC/gam/gam_api.py"

  echo
  echo "### PYTHONPATH"
  EXPECTED="$SRC/gam:$SRC/vendor:$SRC"
  case "$PYTHONPATH" in
    "$EXPECTED"|"$EXPECTED:"*)
      echo "OK PYTHONPATH: $PYTHONPATH"
      ;;
    *)
      echo "ERROR: PYTHONPATH inesperado: $PYTHONPATH" >&2
      echo "EXPECTED prefix: $EXPECTED" >&2
      exit 1
      ;;
  esac

  echo
  echo "### imports"
  PYTHONDONTWRITEBYTECODE=1 \
  PYTHONPATH="$SRC/gam:$SRC/vendor:$SRC${PYTHONPATH:+:$PYTHONPATH}" \
  python - <<'PYDOCTOR'
import atom
import gdata
import gamlib
print("OK import atom:", atom.__file__)
print("OK import gdata:", gdata.__file__)
print("OK import gamlib:", gamlib.__file__)
PYDOCTOR

  echo
  echo "### bytecode"
  BYTECODE="$(
    find "$PY" \( -type d -name __pycache__ -o -type f -name '*.pyc' -o -type f -name '*.pyo' \) -print
  )"
  if [ -n "$BYTECODE" ]; then
    echo "ERROR: bytecode residual:" >&2
    echo "$BYTECODE" >&2
    exit 1
  fi
  echo "OK: sin bytecode"

  echo
  echo "### sensibles tracked"
  SENSITIVE="$(
    git -C "$CELL" ls-files | grep -Ei '(^|/)(\.env|\.master_env)$|oauth|token\.json|secret|private|credential|client_secrets|oauth2service|etc\.json|conf\.json|\.pem$|\.p12$|\.key$|\.crt$|\.cer$' || true
  )"
  if [ -n "$SENSITIVE" ]; then
    echo "ERROR: sensitive tracked paths:" >&2
    echo "$SENSITIVE" >&2
    exit 1
  fi
  echo "OK: no sensitive tracked paths"

  echo
  echo "### api status"
  python "$SRC/gam/gam_api.py" status

  echo
  echo "OK: doctor completo"
}



stage_check_runtime() {
  echo "GAM_py stage-check"

  echo
  echo "### git"
  git -C "$CELL" branch --show-current
  git -C "$CELL" status --short
  if [ -n "$(git -C "$CELL" status --short)" ]; then
    echo "ERROR: working tree no esta limpio" >&2
    exit 1
  fi
  echo "OK: working tree limpio"

  echo
  echo "### doctor"
  doctor_runtime

  echo
  echo "### runtime smoke"
  "$SRC/bin/gam" status
  "$SRC/bin/gam" api status
  "$SRC/bin/gam" live --version | sed -n '1,12p'

  echo
  echo "### bytecode"
  BYTECODE="$(
    find "$PY" \( -type d -name __pycache__ -o -type f -name '*.pyc' -o -type f -name '*.pyo' \) -print
  )"
  if [ -n "$BYTECODE" ]; then
    echo "ERROR: bytecode residual:" >&2
    echo "$BYTECODE" >&2
    exit 1
  fi
  echo "OK: sin bytecode"

  echo
  echo "### referencias obsoletas operativas"
  OBSOLETE="$(
    grep -RInE 'GAM_py/bin/[g]am|GAM_py/live-[s]rc|live-[s]rc/gam.py|live-[s]rc/gamlib|gam-api-[p]y|CELL_[C]ORE|gam-[c]ell' \
      "$CELL/.gitignore" \
      "$CELL/.env.example" \
      "$SRC/bin" \
      "$SRC/gam" \
      "$SRC/atom" \
      "$SRC/vendor" \
      "$SRC/IMPORT_CONTRACT.md" \
      "$PY/README.md" \
      2>/dev/null || true
  )"
  if [ -n "$OBSOLETE" ]; then
    echo "ERROR: referencias obsoletas operativas encontradas:" >&2
    echo "$OBSOLETE" >&2
    exit 1
  fi
  echo "OK: sin referencias obsoletas operativas"

  echo
  echo "### secretos tracked"
  SENSITIVE="$(
    git -C "$CELL" ls-files | grep -Ei '(^|/)(\.env|\.master_env)$|oauth|token\.json|secret|private|credential|client_secrets|oauth2service|etc\.json|conf\.json|\.pem$|\.p12$|\.key$|\.crt$|\.cer$' || true
  )"
  if [ -n "$SENSITIVE" ]; then
    echo "ERROR: sensitive tracked paths:" >&2
    echo "$SENSITIVE" >&2
    exit 1
  fi
  echo "OK: no sensitive tracked paths"

  echo
  echo "### layout"
  tree -a -I '.git|__pycache__|*.pyc|*.pyo' -L 7 "$CELL"

  echo
  echo "OK: stage-check completo"
}


cmd="${1:-help}"
shift || true

case "$cmd" in
  live|run)
    if [ ! -d "$GAMCFGDIR" ]; then
      echo "ERROR: falta GAMCFGDIR=$GAMCFGDIR"
      exit 1
    fi
    if [ ! -f "$SRC/gam/gam.py" ]; then
      echo "ERROR: falta $SRC/gam/gam.py"
      exit 1
    fi
    cd "$SRC"
    exec python "$SRC/gam/gam.py" "$@"
    ;;

  api|api-py)
    exec python "$SRC/gam/gam_api.py" "$@"
    ;;

  json)
    sub="${1:-keys}"
    shift || true
    case "$sub" in
      keys)
        exec python "$SRC/gam/gam_api.py" json keys
        ;;
      list)
        ls -la "$PKI"
        ;;
      status)
        exec python "$SRC/gam/gam_api.py" status
        ;;
      *)
        echo "Uso:"
        echo "  gam json keys"
        echo "  gam json list"
        echo "  gam json status"
        exit 2
        ;;
    esac
    ;;

  pki|config)
    echo "GAM_py PKI externa"
    echo "PKI=$PKI"
    echo "GAMCFGDIR=$GAMCFGDIR"
    echo "CACERTS=$CACERTS"
    echo
    for d in auth-client auth-user auth-service config certs discovery hashes cache runtime; do
      if [ -d "$PKI/$d" ]; then
        echo "$d:"
        ls -la "$PKI/$d"
        echo
      fi
    done
    ;;

  doctor)
    doctor_runtime
    ;;


  stage-check|check)
    stage_check_runtime
    ;;

  status)
    echo "GAM_py bin unico"
    echo "PY=$PY"
    echo "SRC=$SRC"
    echo "CONFIG=$CONFIG"
    echo "PKI=$PKI"
    echo "RUNTIME=$RUNTIME"
    echo "API=$SRC/gam/gam_api.py"
    echo "CACERTS=$CACERTS"
    ;;

  audit|auditar)
    exec bash "$HOME/GAM_CELL_ROTATE_REVOKE_AUDIT.sh" audit
    ;;

  rotate|rotar|token|oauth-token)
    exec bash "$HOME/GAM_CELL_ROTATE_REVOKE_AUDIT.sh" rotate
    ;;

  help|-h|--help)
    cat <<HELP
Uso:
  gam live --version
  gam live checkconn

  gam api status
  gam api version
  gam api checkconn
  gam api json keys

  gam json keys
  gam json list
  gam json status

  gam pki
  gam status
  gam doctor
  gam stage-check
HELP
    ;;

  *)
    echo "ERROR: comando no reconocido: $cmd"
    echo "Usa: gam help"
    exit 2
    ;;
esac
