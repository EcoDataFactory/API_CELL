#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

CELL_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Variables locales de la celda, no globales.
if [ -f "$CELL_DIR/.env" ]; then
  set -a
  . "$CELL_DIR/.env"
  set +a
fi

export TEC_GAM_CELL="${TEC_GAM_CELL:-$CELL_DIR}"
export TEC_GAM_SRC="${TEC_GAM_SRC:-$CELL_DIR/gam-src}"
export TEC_GAM_CONFIG="${TEC_GAM_CONFIG:-$CELL_DIR/config}"
export TEC_GAM_AUDIT="${TEC_GAM_AUDIT:-$CELL_DIR/audit}"

# GAM sí espera GAMCFGDIR, pero aquí vive solo dentro de este proceso.
export GAMCFGDIR="$TEC_GAM_CONFIG"

# Python local preferente.
if [ -x "$CELL_DIR/.venv/bin/python" ]; then
  PY="$CELL_DIR/.venv/bin/python"
else
  PY="$(command -v python)"
fi

exec "$PY" "$TEC_GAM_SRC/src/gam.py" "$@"
