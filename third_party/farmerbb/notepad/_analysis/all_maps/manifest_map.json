{
  "path": "app/src/main/AndroidManifest.xml",
  "permissions": [],
  "features": [
    {
      "name": "android.hardware.touchscreen",
      "required": "false"
    },
    {
      "name": "android.hardware.type.pc",
      "required": "false"
    }
  ],
  "application": {
    "name": ".android.NotepadApplication",
    "label": "${appName}",
    "theme": "@style/Theme.Notepad",
    "allowBackup": "true",
    "supportsRtl": "true"
  },
  "activities": [
    {
      "type": "activity",
      "name": "com.farmerbb.notepad.android.NotepadActivity",
      "exported": "true",
      "launchMode": "singleTop",
      "windowSoftInputMode": "adjustResize",
      "intent_filters": []
    },
    {
      "type": "activity",
      "name": "com.farmerbb.notepad.android.StandaloneEditorActivity",
      "exported": "true",
      "launchMode": "singleTop",
      "windowSoftInputMode": "adjustResize",
      "intent_filters": []
    }
  ],
  "activity_aliases": [
    {
      "type": "activity-alias",
      "name": "com.farmerbb.notepad.MainActivity",
      "targetActivity": "com.farmerbb.notepad.android.NotepadActivity",
      "exported": "true",
      "launchMode": null,
      "intent_filters": [
        {
          "actions": [
            "android.intent.action.MAIN"
          ],
          "categories": [
            "android.intent.category.LAUNCHER",
            "android.intent.category.DEFAULT",
            "android.intent.category.APP_MAPS"
          ],
          "data": []
        }
      ]
    },
    {
      "type": "activity-alias",
      "name": "com.farmerbb.notepad.activity.NoteEditActivity",
      "targetActivity": "com.farmerbb.notepad.android.StandaloneEditorActivity",
      "exported": "true",
      "launchMode": "singleTop",
      "intent_filters": [
        {
          "actions": [
            "android.intent.action.VIEW",
            "android.intent.action.EDIT",
            "android.intent.action.SEND",
            "com.google.android.gm.action.AUTO_SEND"
          ],
          "categories": [
            "android.intent.category.DEFAULT",
            "com.google.android.voicesearch.SELF_NOTE"
          ],
          "data": [
            {
              "android:mimeType": "text/plain"
            }
          ]
        }
      ]
    }
  ],
  "external_intents": [
    {
      "component": "com.farmerbb.notepad.activity.NoteEditActivity",
      "target": "com.farmerbb.notepad.android.StandaloneEditorActivity",
      "actions": [
        "android.intent.action.VIEW",
        "android.intent.action.EDIT",
        "android.intent.action.SEND",
        "com.google.android.gm.action.AUTO_SEND"
      ],
      "categories": [
        "android.intent.category.DEFAULT",
        "com.google.android.voicesearch.SELF_NOTE"
      ],
      "data": [
        {
          "android:mimeType": "text/plain"
        }
      ]
    }
  ],
  "launcher_entries": [
    "com.farmerbb.notepad.MainActivity"
  ]
}
